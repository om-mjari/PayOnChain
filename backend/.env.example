# ==============================
# PayOnChain Gateway .env Config
# ==============================

# Server
PORT=5000
JWT_SECRET=super_secret_jwt_key_change_me

# AWS DynamoDB
AWS_REGION=us-east-1
# AWS_ACCESS_KEY_ID=YOUR_ACCESS_KEY
# AWS_SECRET_ACCESS_KEY=YOUR_SECRET_KEY

# DynamoDB Tables
MERCHANTS_TABLE=PayOnChain_Merchants
ORDERS_TABLE=PayOnChain_Orders
TRANSACTIONS_TABLE=PayOnChain_Transactions
USERS_TABLE=PayOnChain_Users
REFUNDS_TABLE=PayOnChain_Refunds

# Blockchain (Ethereum Sepolia)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com
PRIVATE_KEY=your_deployer_wallet_private_key_here

# Smart Contract (deployed PayOnChain.sol address)
CONTRACT_ADDRESS=your_deployed_contract_address_here

# Frontend URL (for CORS & hosted payment links)
FRONTEND_URL=http://localhost:5173
